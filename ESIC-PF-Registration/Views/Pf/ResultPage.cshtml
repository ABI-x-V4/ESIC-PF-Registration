@{
    ViewData["Title"] = "Result page";
    Layout = null;
}

<style>
    body {
        font-family: Arial, sans-serif;
        background-color: #f4f6f9;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        margin: 0;
    }

    .container {
        background: #ffffff;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        text-align: center;
        width: 400px;
    }

    h1 {
        color: #28a745;
        margin-bottom: 10px;
    }

    p {
        color: #555;
        margin: 10px 0;
        font-size: 16px;
    }

    .btn-home {
        display: inline-block;
        margin-top: 20px;
        padding: 10px 20px;
        background-color: #007bff;
        color: #fff;
        text-decoration: none;
        border-radius: 6px;
    }

        .btn-home:hover {
            background-color: #0056b3;
        }
</style>
<div class="container">
    <h1>✅ Thank You!</h1>
    <p>Your form has been successfully submitted.</p>
    <p>If any additional information is required, our team will contact you.</p>

    <a href="/" class="btn-home">Go to Home</a>
</div>