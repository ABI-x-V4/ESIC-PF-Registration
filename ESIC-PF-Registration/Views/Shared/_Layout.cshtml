<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EMPLOYEE REGISTRATION</title>
    @*   <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" /> *@

    @*  <link rel="stylesheet" href="~/Insfrastructure.DbModels.styles.css" asp-append-version="true" /> *@
    <link href="~/bootstrap.min.css" rel="stylesheet" />
    <!-- Remix Icons -->
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.3.0/fonts/remixicon.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .er-nav-menu a {
            text-decoration: none;
            color: #444;
            padding: 8px 12px;
            display: inline-block;
        }

            .er-nav-menu a.er-active {
                color: #f28c28;
                border-bottom: 2px solid #f28c28;
                font-weight: 600;
            }
    </style>
</head>
<body>
    @if (!(ViewData["HideHeader"] as bool? ?? false))
    {
        <header>

            <nav class="er-navbar">
                <!-- Logo -->
                <a class="er-nav-logo" href="">
                    <img src="https://www.salescom.in/images/logo-new3.png" alt="Salescom" />
                </a>

                <!-- Desktop Nav -->
                <div class="er-nav-center">
                    <ul class="er-nav-menu">
                        <li><a class="er-active" asp-area="" asp-controller="Employee" asp-action="GetAllEmpReg"><i class="ri-home-4-line"></i> ESIC List</a></li>
                        <li><a class="" asp-area="" asp-controller="Pf" asp-action="GetAllPf"><i class="ri-user-add-line"></i> PF List</a></li>
                        @*  <li><a class="" href="#"><i class="ri-user-add-line"></i> Employee Reg</a></li>
                    <li><a class="" asp-area="" asp-controller="Home" asp-action="Privacy"><i class="ri-file-list-3-line"></i> Privacy</a></li>
                    *@
                    </ul>
                </div>

                <!-- User dropdown -->
                <div class="dropdown ms-auto">
                    <button class="er-user-btn" data-bs-toggle="dropdown" aria-expanded="false" id="userDropBtn">
                        <div class="er-user-avatar"><i class="ri-user-3-line"></i></div>
                        @(User?.Identity?.IsAuthenticated == true ? User.Identity!.Name : "Guest")
                        <i class="ri-arrow-down-s-line"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end er-dropdown-menu">
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <li>
                                <form method="post" asp-area="" asp-controller="Login" asp-action="Logout" class="d-inline">
                                    <button type="submit" class="dropdown-item er-logout">
                                        <i class="ri-logout-box-r-line"></i> Sign Out
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li>
                                <a class="dropdown-item er-login" asp-area="" asp-controller="Login" asp-action="Login">
                                    <i class="ri-login-box-line"></i> Sign In
                                </a>
                            </li>
                        }
                    </ul>
                </div>

                <!-- Hamburger (mobile only) -->
                <button class="er-hamburger ms-2" id="hamburger" aria-label="Toggle menu">
                    <span></span><span></span><span></span>
                </button>
            </nav>

            <!-- Mobile Drawer -->
            <div class="er-mobile-drawer" id="mobileDrawer">
                <ul>
                    <li><a class="er-active" asp-area="" asp-controller="Home" asp-action="Index"><i class="ri-home-4-line"></i> Home</a></li>
                    <li><a href="#"><i class="ri-user-add-line"></i> Employee Registration</a></li>
                    <li><a class="" asp-area="" asp-controller="Home" asp-action="Privacy"><i class="ri-file-list-3-line"></i> Privacy</a></li>

                </ul>
            </div>

        </header>
    }

    @if (ViewData["ShowTab"] as bool? ?? false)
    {
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

        var isPfActive = currentController == "Pf" && currentAction == "CreatePfEmployeeReg";
        var isEsicActive = currentController == "Employee" && currentAction == "CreateEmployeeReg";

        
       <header>
                <nav class="er-navbar">
                    <a>
                        <img src="https://www.salescom.in/images/logo-new3.png" alt="Salescom" />
                    </a>
                    <div class="er-nav-center">                        
                       <ul class="er-nav-menu">
                            <li>
                                <a class="@(isPfActive ? "er-active" : "")"
                                   asp-controller="Pf"
                               asp-action="CreatePfEmployeeReg"><i class="ri-home-4-line"></i> Pf Registration</a>
                            <li>
                                <a class="@(isEsicActive ? "er-active" : "")"
                                   asp-controller="Employee"
                               asp-action="CreateEmployeeReg"><i class="ri-home-4-line"></i> ESIC Registration</a>
                       </ul>
                    </div>
                </nav>
            </header>

       
    }

    <div class="container er-page">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container text-center">
            Copyright & Registered Trademarks 2026 Salescom Services Private limited. All Rights Reserved.
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @*    <script src="~/js/jquery-3.6.0.min.js"></script> *@
    <script src="~/js/site.js" asp-append-version="true"></script>




    <script>
        /* ════════════════════════════════
           HAMBURGER TOGGLE
        ════════════════════════════════ */
        const hamburger = document.getElementById('hamburger');
        const drawer    = document.getElementById('mobileDrawer');
        hamburger.addEventListener('click', () => {
          hamburger.classList.toggle('open');
          drawer.classList.toggle('open');
        });
        // Close drawer on link click
        drawer.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
          hamburger.classList.remove('open');
          drawer.classList.remove('open');
        }));
        // Close drawer on outside click
        document.addEventListener('click', e => {
          if (!hamburger.contains(e.target) && !drawer.contains(e.target)) {
            hamburger.classList.remove('open');
            drawer.classList.remove('open');
          }
        });


    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
