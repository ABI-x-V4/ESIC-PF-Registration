@{
    ViewData["Title"] = "Thank You";
    Layout = null; 
}

<main class="ty-page">
    <div class="ty-card">

        <!-- Animated gradient top stripe -->
        <div class="ty-stripe"></div>

        <div class="ty-card-body">

            <!-- Success Icon with pulse rings -->
            <div class="ty-icon-wrap">
                <div class="ty-ring"></div>
                <div class="ty-ring"></div>
                <div class="ty-icon-circle">
                    <i class="ri-check-double-line"></i>
                </div>
            </div>

            <!-- Status tag -->
            <div class="ty-tag">
                <i class="ri-checkbox-circle-fill"></i> Submission Successful
            </div>

            <!-- Heading -->
            <h1 class="ty-heading">Thank You!</h1>

            <!-- Sub-message -->
            <p class="ty-sub">
                Your form has been successfully submitted.<br />
                If any additional information is required, our team will contact you.
            </p>


            <div class="ty-divider"></div>

            <!-- Action buttons -->
            <div class="ty-btn-group">
                <a href="#" class="ty-btn-home">
                    <i class="ri-home-4-line"></i> Go to Home
                </a>

            </div>

        </div>

        <!-- Bottom brand strip -->
        <div class="ty-brand-strip">
            <img src="~/images/logo-new3.png" alt="Salescom" />
            <div class="ty-brand-info">
                <strong>Employee &amp; PF Registration Portal</strong><br />
                Your data is encrypted and stored securely.
            </div>

        </div>

    </div>
</main>