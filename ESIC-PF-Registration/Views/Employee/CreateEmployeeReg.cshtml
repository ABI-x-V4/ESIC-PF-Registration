@model EmployeeRegistrationDTO

@{
    ViewData["Title"] = "Employee Registration";
    ViewData["HideHeader"] = true;
}
<style>
    .sc-submit-btn {
        background: linear-gradient(135deg, #ff8302 0%, #e07200 100%);
        color: #ffffff;
        border: none;
        width: auto;
        padding: 14px;
        font-size: 15px;
        font-weight: 600;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        box-shadow: 0 8px 16px rgba(255, 131, 2, 0.2);
        transition: all 0.2s ease;
        cursor: pointer;
    }

        .sc-submit-btn:hover {
            box-shadow: 0 12px 20px rgba(255, 131, 2, 0.3);
            transform: translateY(-1px);
        }

        .sc-submit-btn:active {
            transform: translateY(0);
            box-shadow: 0 4px 8px rgba(255, 131, 2, 0.15);
        }
</style>
<div class="container mt-4">
    <div class="form-container">
        <div class="row">
            <div class="er-main-heading">
                <div class="er-mh-icon"><i class="ri-user-add-line"></i></div>
                <div class="er-mh-text">
                    <h1>Employee Registration For ESIC Portal</h1>
                    <p>(NOTE :- * Required Fields (all the required fields need to be filed up))</p>
                </div>
                <span class="er-required-badge"><i class="ri-error-warning-line"></i> * Required Fields</span>
            </div>
        </div>

        <div id="previewBanner" class="er-preview-banner" style="display:none;">
            <i class="ri-information-line"></i>
            Preview Mode: Fields are locked. Click <b>Edit</b> to modify or <b>Final Submit</b> to submit.
        </div>
        <form asp-action="CreateEmployeeReg" method="post" enctype="multipart/form-data" id="employeeForm">
            @Html.AntiForgeryToken()

            <div id="nomineeHiddenFields"></div>
            <div id="familyHiddenFields"></div>
            <input type="file" id="FamilyMemberPhotosInput" name="FamilyMemberPhotos" multiple hidden />
            <input type="file" id="FamilyProofDocsInput" name="FamilyProofDocs" multiple hidden />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- ═══════════ SECTION 1 · Personal Information ══════════ -->

            <div class="row">
                <div class="er-section-card px-0">
                    <div class="er-section-header">
                        <div class="er-sh-icon"><i class="ri-id-card-line"></i></div>
                        <h2>Personal Information</h2>
                    </div>
                    <div class="er-section-body">
                        <div class="row g-3">
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">Insured Person Number <span class="text-muted" style="text-transform:none;font-weight:400;font-size:0.7rem;">(if already have)</span></label>
                                    <select class="er-control" asp-for="IsEsicAvailable" id="esicDropdown">
                                        <option value="">--Select--</option>
                                        <option value="1">Yes</option>
                                        <option value="0">No</option>
                                    </select>
                                    <span asp-validation-for="IsEsicAvailable" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4" id="ipBlock" style="display:none;">
                                <label class="er-label">IP Number</label>
                                <input asp-for="IpNumber" class="er-control" />
                                <span asp-validation-for="IpNumber" class="text-danger"></span>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">Is IP Disabled <span class="er-req">*</span></label>

                                    <select asp-for="IsEsicDisabled" class="er-control">
                                        <option value="">--Select--</option>
                                        <option value="1">Yes</option>
                                        <option value="0">No</option>
                                    </select>
                                    <span asp-validation-for="IsEsicDisabled" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">Type of Disability</label>
                                    <input asp-for="TypeOfDisability" class="er-control" />
                                    <span asp-validation-for="TypeOfDisability" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">Name of IP <span class="er-req">*</span> <span class="text-muted" style="text-transform:none;font-weight:400;font-size:0.7rem;">(as per Aadhaar)</span></label>
                                    <input asp-for="Name" class="er-control" />
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">Father / Husband <span class="er-req">*</span></label>

                                    <select asp-for="FatherOrHusband" class="er-control">
                                        <option value="">--Select--</option>
                                        <option value="Father">Father</option>
                                        <option value="Husband">Husband</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">Name of Father / Husband <span class="er-req">*</span></label>
                                    <input asp-for="FatherOrHusbandName" class="er-control" />
                                    <span asp-validation-for="FatherOrHusbandName" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">Date of Birth <span class="er-req">*</span> <span class="text-muted" style="text-transform:none;font-weight:400;font-size:0.7rem;">(as per Aadhaar)</span></label>
                                    <input asp-for="Dob" type="date" class="er-control" />
                                    <span asp-validation-for="Dob" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">Marital Status <span class="er-req">*</span></label>

                                    <select asp-for="MaritalStatus" class="er-control">
                                        <option value="">--Select--</option>
                                        <option value="Married">Married</option>
                                        <option value="Unmarried">Unmarried</option>
                                        <option value="Widowed">Widowe/Widowerd</option>
                                        <option value="Divorced">Divorcee</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">Gender <span class="er-req">*</span></label>

                                    <select asp-for="Gender" class="er-control">
                                        <option value="">--Select--</option>
                                        <option value="Male">Male</option>
                                        <option value="Female">Female</option>
                                        <option value="Transgender">Transgender</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="er-divider"></div>
                        <div class="er-sub-label"><i class="ri-shield-check-line"></i> Identity Documents</div>

                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <div class="er-form-group">
                                    <label class="er-label">Aadhaar no. with copy of E Aadhaar</label>

                                    <input asp-for="AadhaarNo" class="er-control" />
                                    <span asp-validation-for="AadhaarNo" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="er-form-group">
                                    <label class="er-label">Upload E Aadhaar</label>

                                    <input type="file" id="AadhaarFile" name="AadhaarFile" class="er-control" asp-for="AadhaarFile" accept=".pdf" />
                                    <div class="er-note"><i class="ri-information-line"></i> Note : Please upload the latest e-Aadhaar in PDF format downloaded from the UIDAI portal. The file must not be password-protected.</div>
                                    <span asp-validation-for="AadhaarFile" class="text-danger"></span>
                                    <div id="aadhaarPreview" class="mt-3"></div>
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="er-form-group">
                                    <label class="er-label">PAN no. with copy of PAN card</label>
                                    <input asp-for="PanNo" class="er-control" />
                                    <span asp-validation-for="PanNo" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="er-form-group">
                                    <label class="er-label">Upload PAN</label>

                                    <input type="file" id="PanFile" name="PanFile" class="er-control photo-upload " asp-for="PanFile"
                                           onchange="validateFileInput(this)"
                                           data-allowed=".jpg,.jpeg"
                                           data-minsize="50"
                                           data-maxsize="100" />
                                    <div class="er-note"><i class="ri-information-line"></i> Note : Photo size should be between 50 KB to 100 KB in JPG, JPEG Format only.</div>
                                    <div id="panPreview"></div>
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="er-form-group">
                                    <label class="er-label">Self Photo <span class="text-muted" style="text-transform:none;font-weight:400;font-size:0.7rem;">(Soft copy)</span></label>

                                    <input type="file" id="PhotoFile" name="PhotoFile" class="er-control photo-upload" asp-for="PhotoFile"
                                           onchange="validateFileInput(this)"
                                           data-allowed=".jpg,.jpeg"
                                           data-minsize="50"
                                           data-maxsize="100" />
                                    <div class="er-note"><i class="ri-information-line"></i> Note : Photo size should be between 50 KB to 100 KB in JPG, JPEG Format only.</div>
                                    <div id="SelfPhotoPreview"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ══════════════ SECTION 2 · Address Details ════════════ -->

            <div class="row">
                <div class="er-section-card px-0">
                    <div class="er-section-header">
                        <div class="er-sh-icon"><i class="ri-map-pin-2-line"></i></div>
                        <h2>Address Details</h2>
                    </div>
                    <div class="er-section-body">

                        <div class="er-sub-label"><i class="ri-home-pin-line"></i> Present Address</div>
                        <div class="row g-3">
                            <div class="col-12">
                                <div class="er-form-group">
                                    <label class="er-label">Address <span class="er-req">*</span></label>

                                    <input asp-for="EmpAddresses.PstAddress" class="er-control" id="presentAddress" />
                                    <span asp-validation-for="EmpAddresses.PstAddress" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">State <span class="er-req">*</span></label>

                                    <select asp-for="EmpAddresses.PstStateId" asp-items="Model.StateList" class="form-select stateDropdown er-control" data-target="presentdistrictDropdown" id="presentstateDropdown">
                                        <option value="">-- Select State --</option>
                                    </select>
                                    <span asp-validation-for="EmpAddresses.PstStateId" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">District <span class="er-req">*</span></label>
                                    <select asp-for="EmpAddresses.PstDistrictId" class="form-select er-control" id="presentdistrictDropdown">
                                        <option value="">-- Select District --</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">Pin Code</label>

                                    <input asp-for="EmpAddresses.PstPinCode" class="er-control" id="presentPinCode" />
                                    <span asp-validation-for="EmpAddresses.PstPinCode" class="text-danger" id="presentPinCodeValidation"></span>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-6">
                                <div class="er-form-group">
                                    <label class="er-label">Personal Mobile No. <span class="er-req">*</span></label>
                                    <input asp-for="EmpAddresses.PstMobile" type="number" class="er-control" id="presentMobile" />
                                    <span asp-validation-for="EmpAddresses.PstMobile" class="text-danger" id="presentMobileValidation"></span>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-6">
                                <div class="er-form-group">
                                    <label class="er-label">Personal Email </label>
                                    <input asp-for="EmpAddresses.PstEmail" type="email" class="er-control" id="presentEmail" />
                                    <span asp-validation-for="EmpAddresses.PstEmail" class="text-danger" id="presentEmailValidation"></span>
                                </div>
                            </div>
                        </div>

                        <label class="er-check-row mt-1">

                            <input type="checkbox" class="form-check-input" id="sameAddressCheck" asp-for="EmpAddresses.IsSameAddressBool">
                            <label for="sameAddress"><i class="ri-file-copy-line" style="color:#ff8302"></i> Same as Present Address</label>

                        </label>

                        <div class="er-sub-label"><i class="ri-building-4-line"></i> Permanent Address</div>
                        <div class="row g-3" id="permanentAddr">
                            <div class="col-12">
                                <div class="er-form-group">
                                    <label class="er-label">Address <span class="er-req">*</span></label>
                                    <input asp-for="EmpAddresses.PmtAddress" class="er-control" id="permanentAddress" />
                                    <span asp-validation-for="EmpAddresses.PmtAddress" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">State <span class="er-req">*</span></label>


                                    <select asp-for="EmpAddresses.PmtStateId"
                                            asp-items="Model.StateList" id="permanentstateDropdown"
                                            class="form-select stateDropdown er-control" data-target="permanentdistrictDropdown">
                                        <option value="">-- Select State --</option>
                                    </select>
                                    <span asp-validation-for="EmpAddresses.PmtStateId" class="text-danger"></span>

                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">District <span class="er-req">*</span></label>
                                    <select asp-for="EmpAddresses.PmtDistrictId"
                                            class="form-select er-control"
                                            id="permanentdistrictDropdown">
                                        <option value="">-- Select District --</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">Pin Code</label>
                                    <input asp-for="EmpAddresses.PmtPinCode" class="er-control" id="permanentPinCode" />
                                    <span asp-validation-for="EmpAddresses.PmtPinCode" class="text-danger" id="permanentPinCodeValidation"></span>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-6">
                                <div class="er-form-group">
                                    <label class="er-label">Residence Mobile No. <span class="er-req">*</span></label>
                                    <input asp-for="EmpAddresses.PmtMobile" type="number" class="er-control" id="permanentMobile" />
                                    <span asp-validation-for="EmpAddresses.PmtMobile" class="text-danger" id="permanentMobileValidation"></span>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-6">
                                <div class="er-form-group">
                                    <label class="er-label">Email </label>
                                    <input asp-for="EmpAddresses.PmtEmail" type="email" class="er-control" id="permanentEmail" />
                                    <span asp-validation-for="EmpAddresses.PmtEmail" class="text-danger" id="permanentEmailValidation"></span>
                                </div>
                            </div>
                        </div>

                        <div class="er-divider"></div>
                        <div class="er-sub-label"><i class="ri-hospital-line"></i> ESIC Dispensary / IMP / mEUD Details</div>
                        <div class="row g-3">
                            <div class="col-12 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">Dispensary or IMP or mEUD for IP</label>
                                    <input asp-for="DispenseryDetails.DispensaryOrImpormEudforIp" class="er-control" />
                                    <span asp-validation-for="DispenseryDetails.DispensaryOrImpormEudforIp" class="text-danger"></span>

                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">State</label>

                                    <select asp-for="DispenseryDetails.StateIdForIp" asp-items="Model.StateList" class="form-select stateDropdown er-control" data-target="dispensaryDistrictDropdown">
                                        <option value="">-- Select State --</option>
                                    </select>
                                    <span asp-validation-for="DispenseryDetails.StateIdForIp" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">District</label>

                                    <select asp-for="DispenseryDetails.DistrictIdForIp" class="er-control" id="dispensaryDistrictDropdown">
                                        <option value="">-- Select District --</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="er-form-group">
                                    <label class="er-label">Name of ESIC Dispensary / IMP / mEUD for IP</label>

                                    <input asp-for="DispenseryDetails.DispensaryNameForIp" class="er-control" />
                                    <span asp-validation-for="DispenseryDetails.DispensaryNameForIp" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="er-form-group">
                                    <label class="er-label">Dispensary / IMP / mEUD for Family Members</label>
                                    <input asp-for="DispenseryDetails.DispensaryOrImpormEudforFamily" class="er-control" />
                                    <span asp-validation-for="DispenseryDetails.DispensaryOrImpormEudforFamily" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">State</label>
                                    <select asp-for="DispenseryDetails.StateIdForFamily" asp-items="Model.StateList" class="form-select stateDropdown er-control"
                                            data-target="dispensaryDistrictDropdownForFamily">
                                        <option value="">-- Select State --</option>
                                    </select>
                                    <span asp-validation-for="DispenseryDetails.StateIdForFamily" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">District</label>
                                    <select asp-for="DispenseryDetails.DistrictIdForFamily" class="er-control" id="dispensaryDistrictDropdownForFamily">
                                        <option value="">-- Select District --</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-12 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">Name of ESIC Dispensary/ IMP/ mEUD For Family Members</label>

                                    <input asp-for="DispenseryDetails.DispensaryNameForFamily" class="er-control" />
                                    <span asp-validation-for="DispenseryDetails.DispensaryNameForFamily" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ═════════ SECTION 3 · Current Employer ═══════════════ -->
            <div class="row">
                <div class="er-section-card px-0">
                    <div class="er-section-header">
                        <div class="er-sh-icon"><i class="ri-building-line"></i></div>
                        <h2>Current Employer's Particulars</h2>
                    </div>
                    <div class="er-section-body">
                        <div class="row g-3">
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">Date of Appointment (DOI) <span class="er-req">*</span></label>
                                    <input asp-for="EmploymentDetails.DojofCurrentEmployer" type="date" class="er-control" />
                                    <span asp-validation-for="EmploymentDetails.DojofCurrentEmployer" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ═════════════ SECTION 4 · Previous Employer ════════════ -->

            <div class="row">
                <div class="er-section-card px-0">
                    <div class="er-section-header">
                        <div class="er-sh-icon"><i class="ri-history-line"></i></div>
                        <h2>Have Previous Employer</h2>
                        <input type="checkbox"
                               asp-for="EmploymentDetails.HasPreviousEmployerBool"
                               class="form-check-input"
                               id="hasPrevEmployerCheck" />
                    </div>
                    <div class="er-section-body" id="prevEmployerSection">
                        <div class="er-tip"><i class="ri-information-line"></i> In case of any Previous employment please fill up the details below:</div>
                        <div class="row g-3">
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">Employer's Code No.</label>
                                    <input asp-for="EmploymentDetails.EmployerCode" class="er-control" />
                                    <span asp-validation-for="EmploymentDetails.EmployerCode" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">Previous Insurance No.</label>
                                    <input asp-for="EmploymentDetails.PreviousInsuarenceNo" class="er-control" />
                                    <span asp-validation-for="EmploymentDetails.PreviousInsuarenceNo" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">Name of the Employer</label>
                                    <input asp-for="EmploymentDetails.EmployerName" class="er-control" />
                                    <span asp-validation-for="EmploymentDetails.EmployerName" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="er-form-group">
                                    <label class="er-label">Address of Employer</label>
                                    <input asp-for="EmploymentDetails.EmployerAddress" class="er-control" />
                                    <span asp-validation-for="EmploymentDetails.EmployerAddress" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">State</label>
                                    <select asp-for="EmploymentDetails.StateId"
                                            asp-items="Model.StateList"
                                            class="form-select stateDropdown er-control" data-target="employmentDistrictDropdown">
                                        <option value="">-- Select State --</option>
                                    </select>
                                    <span asp-validation-for="EmploymentDetails.StateId" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">District</label>
                                    <select asp-for="EmploymentDetails.DistrictId"
                                            class="er-control " id="employmentDistrictDropdown">
                                        <option value="">-- Select District --</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="er-form-group">
                                    <label class="er-label">Pin Code</label>
                                    <input asp-for="EmploymentDetails.Pincode" class="er-control" />
