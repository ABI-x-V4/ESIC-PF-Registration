@functions {

    public bool IsImage(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
            return false;

        var ext = System.IO.Path.GetExtension(path).ToLower();

        return ext == ".jpg"
            || ext == ".jpeg"
            || ext == ".png"
            || ext == ".gif"
            || ext == ".webp";
    }

    public bool IsPdf(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
            return false;

        return System.IO.Path.GetExtension(path).ToLower() == ".pdf";
    }
}
